generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
  // Note: this project stays on Prisma 6.19.x for now because MongoDB support for
  // Prisma 7 is not available yet. Once MongoDB is supported in Prisma 7, move the
  // connection URL fully to prisma.config.ts and remove this line.
}

model Account {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @db.ObjectId
  type              String
  provider          String
  providerAccountId String   @map("provider_account_id")
  refresh_token     String?  @db.String
  access_token      String?  @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.String
  session_state     String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Optional for WebAuthn support
model Authenticator {
  credentialID         String  @id @map("_id")
  userId               String  @db.ObjectId
  providerAccountId    String  @map("provider_account_id")
  credentialPublicKey  String  @map("credential_public_key")
  counter              Int
  credentialDeviceType String  @map("credential_device_type")
  credentialBackedUp   Boolean @map("credential_backed_up")
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, credentialID])
}

model Domain {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  longDescription  String
  shortDescription String
  order            Int? // Ordre dans le programme
  discipline       DomainDiscipline? // Discipline dominante pour Physique-Chimie
  isActive         Boolean           @default(true)

  // Relations
  subjectId String  @db.ObjectId
  subject   Subject @relation(fields: [subjectId], references: [id])

  themeIds String[]      @default([]) @db.ObjectId
  themes   Theme[]       @relation(fields: [themeIds], references: [id])
  scopes   DomainScope[]

  subdomains Subdomain[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([longDescription, subjectId])
}

model Subdomain {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  title       String
  shortTitle  String?
  slug        String
  description String?
  order       Int?
  isActive    Boolean @default(true)

  subjectId String  @db.ObjectId
  subject   Subject @relation(fields: [subjectId], references: [id])

  domainId String @db.ObjectId
  domain   Domain @relation(fields: [domainId], references: [id])

  themeIds String[] @default([]) @db.ObjectId
  themes   Theme[]  @relation(fields: [themeIds], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([subjectId, slug])
  @@index([subjectId])
  @@index([domainId])
  @@index([subjectId, domainId])
  @@index([isActive])
}

model DomainScope {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  domainId String @db.ObjectId
  domain   Domain @relation(fields: [domainId], references: [id])

  diplomaId String?  @db.ObjectId
  diploma   Diploma? @relation(fields: [diplomaId], references: [id])

  gradeId String? @db.ObjectId
  grade   Grade?  @relation(fields: [gradeId], references: [id])

  divisionId String?   @db.ObjectId
  division   Division? @relation(fields: [divisionId], references: [id])

  teachingId String?   @db.ObjectId
  teaching   Teaching? @relation(fields: [teachingId], references: [id])

  curriculumId String?     @db.ObjectId
  curriculum   Curriculum? @relation(fields: [curriculumId], references: [id])

  labelOverride String?
  order         Int?
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([domainId])
  @@index([diplomaId])
  @@index([gradeId])
  @@index([divisionId])
  @@index([teachingId])
  @@index([curriculumId])
  @@index([domainId, diplomaId, gradeId, divisionId, teachingId, curriculumId])
}

model Teaching {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  longDescription  String // ex: "Spécialité Mathématiques", "Tronc Commun Sciences"
  shortDescription String? // ex: "Spé Maths", "TC Sciences"
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  gradeId String @db.ObjectId
  grade   Grade  @relation(fields: [gradeId], references: [id])

  subjectId String  @db.ObjectId
  subject   Subject @relation(fields: [subjectId], references: [id])

  examPapers   ExamPaper[]
  domainScopes DomainScope[]

  @@unique([longDescription, gradeId])
}

enum TeachingType {
  SPECIALITE
  TRONC_COMMUN
  OPTION
  COMPLEMENTAIRE
  EXPERT
}

enum DomainDiscipline {
  PHYSIQUE
  CHIMIE
  TRANSVERSAL
}

enum HealthProgramType {
  PASS
  LAS
  LAS_SPS
  HEALTH_LICENSE_2027
  OTHER
}

enum HealthStudyLevel {
  L1
  L2
  L3
  OTHER
}

enum HealthBlockType {
  HEALTH
  DISCIPLINARY
  TRANSVERSAL
  SPECIALTY
  OTHER
}

enum ContentVertical {
  SECONDARY
  BTS
  HEALTH
  COMMON
}

enum ChapterAssignmentContextType {
  SUBJECT
  HEALTH_COURSE_UNIT
  HEALTH_TEACHING_ELEMENT
  BTS_TEACHING
  GENERIC
}

enum HealthCourseUnitCoverageStatus {
  STRUCTURE_ONLY
  THEMES_MAPPED
  QUESTIONS_AVAILABLE
  READY
}

model HealthInstitution {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  shortName   String?
  slug        String  @unique
  uaiCode     String?
  city        String?
  academy     String?
  region      String?
  department  String?
  websiteUrl  String?
  isActive    Boolean @default(true)
  isPublished Boolean @default(true)

  programVersions HealthProgramVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, isPublished])
  @@index([uaiCode])
  @@index([city])
}

model HealthProgram {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  type        HealthProgramType
  code        String            @unique
  label       String
  description String?
  isActive    Boolean           @default(true)
  isPublished Boolean           @default(true)

  versions HealthProgramVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive, isPublished])
}

model HealthProgramVersion {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  institutionId   String            @db.ObjectId
  institution     HealthInstitution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  programId       String            @db.ObjectId
  program         HealthProgram     @relation(fields: [programId], references: [id], onDelete: Cascade)
  label           String
  slug            String
  academicYear    String
  studyLevel      HealthStudyLevel  @default(L1)
  sourceUrl       String?
  sourceLabel     String?
  sourceCheckedAt DateTime?
  notes           String?
  isCurrent       Boolean           @default(false)
  isActive        Boolean           @default(true)
  isPublished     Boolean           @default(false)

  pathways    HealthPathway[]
  blocks      HealthBlock[]
  courseUnits HealthCourseUnit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([institutionId, slug])
  @@index([institutionId])
  @@index([programId])
  @@index([academicYear])
  @@index([isCurrent])
  @@index([isActive, isPublished])
}

model HealthPathway {
  id               String               @id @default(auto()) @map("_id") @db.ObjectId
  programVersionId String               @db.ObjectId
  programVersion   HealthProgramVersion @relation(fields: [programVersionId], references: [id], onDelete: Cascade)
  name             String
  slug             String
  campus           String?
  parcoursupCode   String?
  sourceUrl        String?
  description      String?
  order            Int                  @default(0)
  isDefault        Boolean              @default(false)
  isActive         Boolean              @default(true)
  isPublished      Boolean              @default(false)

  blocks      HealthBlock[]
  courseUnits HealthCourseUnit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([programVersionId, slug])
  @@index([programVersionId])
  @@index([isActive, isPublished])
  @@index([order])
}

model HealthBlock {
  id               String               @id @default(auto()) @map("_id") @db.ObjectId
  programVersionId String               @db.ObjectId
  programVersion   HealthProgramVersion @relation(fields: [programVersionId], references: [id], onDelete: Cascade)
  pathwayId        String?              @db.ObjectId
  pathway          HealthPathway?       @relation(fields: [pathwayId], references: [id], onDelete: SetNull)
  type             HealthBlockType
  title            String
  slug             String
  description      String?
  ects             Int?
  order            Int                  @default(0)
  isActive         Boolean              @default(true)
  isPublished      Boolean              @default(false)

  courseUnits HealthCourseUnit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([programVersionId, pathwayId, slug])
  @@index([programVersionId])
  @@index([pathwayId])
  @@index([type])
  @@index([isActive, isPublished])
  @@index([order])
}

model HealthCourseUnit {
  id                     String               @id @default(auto()) @map("_id") @db.ObjectId
  programVersionId       String               @db.ObjectId
  programVersion         HealthProgramVersion @relation(fields: [programVersionId], references: [id], onDelete: Cascade)
  pathwayId              String?              @db.ObjectId
  pathway                HealthPathway?       @relation(fields: [pathwayId], references: [id], onDelete: SetNull)
  blockId                String               @db.ObjectId
  block                  HealthBlock          @relation(fields: [blockId], references: [id], onDelete: Cascade)
  code                   String?
  title                  String
  shortTitle             String?
  slug                   String
  description            String?
  semester               Int?
  ects                   Int?
  order                  Int                  @default(0)
  isCommonToAllPathways  Boolean              @default(false)
  isHealthAccessRelevant Boolean              @default(true)
  coverageStatus         HealthCourseUnitCoverageStatus @default(STRUCTURE_ONLY)
  sourceUrl              String?
  sourceLabel            String?
  sourceCheckedAt        DateTime?
  themeIds               String[]             @default([]) @db.ObjectId
  themes                 Theme[]              @relation(fields: [themeIds], references: [id])
  teachingElements       HealthTeachingElement[]
  isActive               Boolean              @default(true)
  isPublished            Boolean              @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([programVersionId, pathwayId, slug])
  @@index([programVersionId])
  @@index([pathwayId])
  @@index([blockId])
  @@index([semester])
  @@index([isActive, isPublished])
  @@index([order])
}

model HealthTeachingElement {
  id              String                         @id @default(auto()) @map("_id") @db.ObjectId
  courseUnitId    String                         @db.ObjectId
  courseUnit      HealthCourseUnit               @relation(fields: [courseUnitId], references: [id], onDelete: Cascade)
  code            String?
  title           String
  shortTitle      String?
  slug            String
  description     String?
  order           Int                            @default(0)
  coverageStatus  HealthCourseUnitCoverageStatus @default(STRUCTURE_ONLY)
  sourceUrl       String?
  sourceLabel     String?
  sourceCheckedAt DateTime?
  themeIds        String[]                       @default([]) @db.ObjectId
  themes          Theme[]                        @relation(fields: [themeIds], references: [id])
  isActive        Boolean                        @default(true)
  isPublished     Boolean                        @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseUnitId, slug])
  @@index([courseUnitId])
  @@index([isActive, isPublished])
  @@index([order])
}

// Programme scolaire (ex: Programmes 2019, Réforme 2020, etc.)
model Curriculum {
  id               String  @id @default(auto()) @map("_id") @db.ObjectId
  longDescription  String // ex: "Programme 2019", "Réforme Bac 2020", "Programme 2010"
  shortDescription String? // Description détaillée du programme

  // Période de validité du programme (mois/année)
  startDate DateTime // Date de mise en vigueur (ex: 2020-09-01 pour septembre 2020)
  endDate   DateTime? // Date de fin (null si toujours en vigueur)

  // Applicabilité (MongoDB: liste d'IDs pour many-to-many)
  // Un programme peut concerner plusieurs enseignements (ex: réforme 2020 pour toutes les spés)
  teachingIds String[] @db.ObjectId

  // Métadonnées
  isActive Boolean @default(true) // Programme actuellement en vigueur
  notes    String? // Notes complémentaires

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  examPapers   ExamPaper[]
  domainScopes DomainScope[]

  @@unique([longDescription, startDate])
}

model Diploma {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  longDescription  String
  shortDescription String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  examPapers   ExamPaper[]
  domainScopes DomainScope[]

  @@unique([longDescription, shortDescription])
}

model Division {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  longDescription  String
  shortDescription String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  examPapers   ExamPaper[]
  domainScopes DomainScope[]

  @@unique([longDescription, shortDescription])
}

model ExaminationCenter {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  description String
  isActive    Boolean? @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([description])
}

// Sujet d'annales (conteneur d'exercices)
model ExamPaper {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Métadonnées administratives
  label       String // ex : "Métropole juin 2024 Jour 1"
  sessionYear Int // ex : 2024 (année scolaire de la session)
  sessionDay  String? // ex : "Jour 1", "Jour 2", "Sujet A", optionnel
  source      String  @default("Officiel") // Source standardisée (liste admin)
  sourceUrl   String? // URL de la source si disponible (APMEP, Labolycee, etc.)

  // Date réelle de l'examen
  examDay   Int? // Jour de l'examen (1-31), optionnel
  examMonth Int? // Mois de l'examen (1-12), optionnel
  examYear  Int? // Année de l'examen, optionnel

  // Références pédagogiques (hiérarchie complète)
  diplomaId String  @db.ObjectId
  diploma   Diploma @relation(fields: [diplomaId], references: [id])

  divisionId String?   @db.ObjectId // Optionnel (ex: Brevet)
  division   Division? @relation(fields: [divisionId], references: [id])

  gradeId String @db.ObjectId
  grade   Grade  @relation(fields: [gradeId], references: [id])

  // Le Teaching est le point d'ancrage principal (ex: "Spé Maths Terminale")
  teachingId String   @db.ObjectId
  teaching   Teaching @relation(fields: [teachingId], references: [id])

  // Association au programme scolaire
  curriculumId String?     @db.ObjectId // Optionnel (ex: Brevet)
  curriculum   Curriculum? @relation(fields: [curriculumId], references: [id])

  // Centres d'examen (many-to-many via array d'IDs)
  examinationCenterIds String[] @default([]) @db.ObjectId

  // URLs du sujet complet
  subjectUrl String? // URL du PDF complet

  // Métadonnées globales du sujet
  totalDuration Int? // Durée totale en minutes
  totalPoints   Int? // Total de points

  // DEPRECATED: Métadonnées déplacées au niveau Exercise
  // Ces champs restent pour compatibilité mais ne sont plus utilisés
  domainIds           String[]  @default([]) @db.ObjectId /// @deprecated Utiliser Exercise.themeIds
  themeIds            String[]  @default([]) @db.ObjectId /// @deprecated Utiliser Exercise.themeIds
  estimatedDuration   Int? /// @deprecated Utiliser Exercise.estimatedDuration
  estimatedDifficulty Int? /// @deprecated Utiliser Exercise.estimatedDifficulty
  summary             String? /// @deprecated Utiliser Exercise.summary
  enrichmentStatus    String    @default("pending") /// @deprecated Utiliser Exercise.enrichmentStatus
  enrichedAt          DateTime? /// @deprecated Utiliser Exercise.enrichedAt

  // Relations
  exercises   Exercise[] // Les exercices contenus dans ce sujet
  corrections Correction[] // Corrections globales (optionnel)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([label, sessionYear, teachingId])
}

enum ExerciseType {
  NORMAL
  QCM
  TRUE_FALSE
  OTHER
}

enum QuizDifficulty {
  EASY
  MEDIUM
  HARD
}

enum TrainingQuizStage {
  DISCOVER
  PRACTICE
  MASTER
}

enum ChapterSectionKind {
  THEME
  SYNTHESIS
}

// Exercice d'annales (unité de recherche)
model Exercise {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Traçabilité du sujet parent
  examPaperId String    @db.ObjectId
  examPaper   ExamPaper @relation(fields: [examPaperId], references: [id], onDelete: Cascade)

  // Position dans le sujet
  exerciseNumber Int // 1, 2, 3...
  label          String? // "Exercice 3", "Partie A", "Question de synthèse"
  points         Int? // Points attribués à cet exercice
  pageStart      Int? // Page de debut (1-based)
  pageEnd        Int? // Page de fin (1-based)
  exerciseType   ExerciseType? @default(NORMAL) // Type d'exercice (QCM, vrai/faux, etc.)

  // Titre et énoncé (pour recherche full-text future)
  title     String? // ex: "Titrage acide-base d'un vinaigre"
  statement String? @db.String // Énoncé complet (extrait via OCR)

  // Tagging pédagogique précis (au niveau exercice)
  themeIds String[] @default([]) @db.ObjectId // Thèmes couverts dans CET exercice

  // URLs spécifiques (optionnel si découpage des PDFs)
  exerciseUrl String? // URL de l'exercice isolé

  // Métadonnées enrichies (via IA)
  estimatedDuration   Int? // Durée estimée en minutes pour CET exercice
  estimatedDifficulty Int? // Difficulté 1-5
  summary             String? // Résumé automatique de l'exercice
  keywords            String[] @default([]) // Mots-clés extraits automatiquement

  // Statut d'enrichissement
  enrichmentStatus String    @default("pending") // "pending" | "completed" | "failed"
  enrichedAt       DateTime? // Date d'enrichissement

  // Relations
  corrections    ExerciseCorrection[]
  historyEntries UserExerciseHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examPaperId, exerciseNumber])
}

// Standardized sources for corrections (admin-managed list)
model CorrectionSource {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  label    String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([label])
}

// Corrections spécifiques à un exercice
model ExerciseCorrection {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  exerciseId String   @db.ObjectId
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  source String // "APMEP", "YouTube - Prof Dupont", etc.
  url    String // Lien vers la correction
  type   String @default("pdf") // "pdf", "video", "html"

  // Métadonnées optionnelles
  quality Int? // Note de qualité 1-5
  author  String? // Auteur si connu

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([exerciseId, source, url])
}

// Corrections externes pour un sujet d'examen
model Correction {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  examPaperId String    @db.ObjectId
  examPaper   ExamPaper @relation(fields: [examPaperId], references: [id], onDelete: Cascade)

  source String // "APMEP", "LaboLycée", "Académie de Paris", etc.
  url    String // lien vers la correction
  type   String @default("pdf") // "pdf", "video", "html"

  // Métadonnées optionnelles
  quality Int? // note de qualité 1-5
  author  String? // auteur si connu

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examPaperId, source, url])
}

model Grade {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  longDescription  String
  shortDescription String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  teachings    Teaching[]
  examPapers   ExamPaper[]
  domainScopes DomainScope[]

  @@unique([longDescription, shortDescription])
}

enum Role {
  USER
  ADMIN
}

enum AuthLogAction {
  SIGN_IN
  SIGN_OUT
}

enum UsageEventType {
  SEARCH
}

enum ErrorLogType {
  PDF_404
  API_SLOW
}

enum UsageDailyCategory {
  SEARCH_TOTAL
  SEARCH_ZERO
  SEARCH_TERM
  SEARCH_DIPLOMA
  SEARCH_SUBJECT
  SEARCH_SESSION
}

enum ErrorDailyCategory {
  PDF_404
  API_SLOW
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique @map("session_token")
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}

model Subject {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  longDescription  String
  shortDescription String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  teachings  Teaching[]
  domains    Domain[]
  subdomains Subdomain[]
  chapters   Chapter[]

  @@unique([longDescription, shortDescription])
}

model Theme {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  shortTitle String?

  // DEPRECATED à terme : préférer Theme → Subdomain → Domain
  domainIds String[] @default([]) @db.ObjectId
  domains   Domain[] @relation(fields: [domainIds], references: [id])

  subdomainIds String[]    @default([]) @db.ObjectId
  subdomains   Subdomain[] @relation(fields: [subdomainIds], references: [id])

  chapterIds String[]  @default([]) @db.ObjectId
  chapters   Chapter[] @relation(fields: [chapterIds], references: [id])

  healthCourseUnitIds String[]           @default([]) @db.ObjectId
  healthCourseUnits   HealthCourseUnit[] @relation(fields: [healthCourseUnitIds], references: [id])

  healthTeachingElementIds String[]                @default([]) @db.ObjectId
  healthTeachingElements   HealthTeachingElement[] @relation(fields: [healthTeachingElementIds], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Chapter {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  vertical    ContentVertical @default(SECONDARY)
  title       String
  shortTitle  String?
  slug        String
  description String?
  /// @deprecated Niveau historique libre. Ne pas utiliser pour les nouveaux développements.
  /// Le niveau doit être déduit du contexte via ChapterAssignment -> Teaching -> Grade.
  level       String  @default("terminale")
  order       Int
  coverageStatus HealthCourseUnitCoverageStatus @default(STRUCTURE_ONLY)
  sourceUrl   String?
  sourceLabel String?
  sourceCheckedAt DateTime?
  isActive    Boolean @default(true)
  isPublished Boolean @default(true)

  subjectId String  @db.ObjectId
  subject   Subject @relation(fields: [subjectId], references: [id])

  domainIds String[] @default([]) @db.ObjectId
  themeIds  String[] @default([]) @db.ObjectId
  themes    Theme[]  @relation(fields: [themeIds], references: [id])

  quizQuestions               QuizQuestion[]
  sections                    ChapterSection[]
  trainingQuizzes             TrainingQuiz[]
  trainingQuizProgressEntries UserTrainingQuizProgress[]
  assignments                 ChapterAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([subjectId, slug])
  @@unique([subjectId, order])
  @@index([subjectId, isActive, isPublished])
  @@index([level])
}

model ChapterAssignment {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  chapterId String  @db.ObjectId
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  vertical ContentVertical

  contextType ChapterAssignmentContextType
  contextId   String @db.ObjectId

  titleOverride      String?
  shortTitleOverride String?
  slugOverride       String?
  descriptionOverride String?

  order Int @default(0)

  coverageStatus HealthCourseUnitCoverageStatus @default(STRUCTURE_ONLY)

  sourceUrl       String?
  sourceLabel     String?
  sourceCheckedAt DateTime?

  isActive    Boolean @default(true)
  isPublished Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contextType, contextId, chapterId])
  @@unique([contextType, contextId, order])
  @@index([chapterId])
  @@index([vertical])
  @@index([contextType, contextId])
  @@index([isActive, isPublished])
  @@index([order])
}

model ChapterSection {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  order       Int
  kind        ChapterSectionKind @default(THEME)
  isPublished Boolean            @default(true)
  themeIds    String[]           @default([]) @db.ObjectId

  chapterId String  @db.ObjectId
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  quizzes TrainingQuiz[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chapterId, order])
  @@index([chapterId, kind, isPublished])
}

model TrainingQuiz {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  slug        String
  title       String
  description String?
  order       Int
  stage       TrainingQuizStage?
  isPublished Boolean            @default(true)

  chapterId String  @db.ObjectId
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  sectionId String         @db.ObjectId
  section   ChapterSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  questionGroups  TrainingQuizQuestionGroup[]
  questionLinks   TrainingQuizQuestion[]
  progressEntries UserTrainingQuizProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chapterId, slug])
  @@unique([sectionId, order])
  @@index([chapterId, isPublished])
  @@index([sectionId, isPublished])
}

model TrainingQuizQuestionGroup {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  title           String?
  sharedStatement String  @db.String
  order           Int

  quizId String       @db.ObjectId
  quiz   TrainingQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  questionLinks TrainingQuizQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([quizId, order])
  @@index([quizId])
}

model QuizQuestion {
  id                 String         @id @default(auto()) @map("_id") @db.ObjectId
  difficulty         QuizDifficulty
  question           String         @db.String
  choices            Json
  correctChoiceIndex Int
  explanation        String         @db.String
  order              Int
  isPublished        Boolean        @default(true)
  themeIds           String[]       @default([]) @db.ObjectId

  chapterId String  @db.ObjectId
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  quizLinks TrainingQuizQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chapterId, order])
  @@index([chapterId, difficulty, isPublished])
  @@index([difficulty])
}

model TrainingQuizQuestion {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  order Int

  quizId String       @db.ObjectId
  quiz   TrainingQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  groupId String?                    @db.ObjectId
  group   TrainingQuizQuestionGroup? @relation(fields: [groupId], references: [id])

  questionId String       @db.ObjectId
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([quizId, order])
  @@unique([quizId, questionId])
  @@index([groupId])
  @@index([questionId])
}

model User {
  id                          String                     @id @default(auto()) @map("_id") @db.ObjectId
  name                        String?
  email                       String?                    @unique
  emailVerified               DateTime?                  @map("email_verified")
  image                       String?
  accounts                    Account[]
  sessions                    Session[]
  roles                       Role                       @default(USER)
  // Optional for WebAuthn support
  Authenticator               Authenticator[]
  authLogs                    AuthLog[]
  activity                    UserActivity?
  entitlements                UserEntitlement[]
  subscriptions               UserSubscription[]
  exerciseHistory             UserExerciseHistory[]
  trainingQuizProgressEntries UserTrainingQuizProgress[]
  createdAt                   DateTime                   @default(now())
  updatedAt                   DateTime                   @updatedAt
}

model UserTrainingQuizProgress {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  userId         String    @db.ObjectId
  chapterId      String    @db.ObjectId
  quizId         String    @db.ObjectId
  bestScore      Int       @default(0)
  totalQuestions Int       @default(0)
  successRate    Int       @default(0)
  attemptsCount  Int       @default(0)
  lastAttemptAt  DateTime  @default(now())
  masteredAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter Chapter      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  quiz    TrainingQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId])
  @@index([userId, chapterId])
  @@index([quizId])
}

model UserActivity {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @db.ObjectId
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastExamPaperId  String?  @db.ObjectId
  lastExerciseId   String?  @db.ObjectId
  lastSubjectId    String?  @db.ObjectId
  lastSessionYear  Int?
  currentGoalLabel String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId])
  @@index([lastExamPaperId])
  @@index([lastExerciseId])
  @@index([lastSubjectId])
  @@index([lastSessionYear])
}

model UserExerciseHistory {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  exerciseId   String   @db.ObjectId
  lastViewedAt DateTime @default(now())
  createdAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@index([userId])
  @@index([exerciseId])
  @@index([lastViewedAt])
}

model Entitlement {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  planLinks        SubscriptionPlanEntitlement[]
  userEntitlements UserEntitlement[]
}

model SubscriptionPlan {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entitlements      SubscriptionPlanEntitlement[]
  userSubscriptions UserSubscription[]
}

model SubscriptionPlanEntitlement {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  planId        String   @db.ObjectId
  entitlementId String   @db.ObjectId
  createdAt     DateTime @default(now())

  plan        SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  entitlement Entitlement      @relation(fields: [entitlementId], references: [id], onDelete: Cascade)

  @@unique([planId, entitlementId])
  @@index([planId])
  @@index([entitlementId])
}

model UserEntitlement {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  entitlementId String   @db.ObjectId
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entitlement Entitlement @relation(fields: [entitlementId], references: [id], onDelete: Cascade)

  @@unique([userId, entitlementId])
  @@index([userId])
  @@index([entitlementId])
}

model UserSubscription {
  id        String             @id @default(auto()) @map("_id") @db.ObjectId
  userId    String             @db.ObjectId
  planId    String             @db.ObjectId
  status    SubscriptionStatus @default(ACTIVE)
  startsAt  DateTime           @default(now())
  endsAt    DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([planId])
  @@index([status])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
}

model AuthLog {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  userId    String        @db.ObjectId
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    AuthLogAction
  provider  String?
  createdAt DateTime      @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model UsageEvent {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  type         UsageEventType
  searchTerm   String?
  resultsCount Int
  diploma      String?
  subject      String?
  teachingId   String?
  sessionYear  Int?
  themeIds     String[]       @default([]) @db.ObjectId
  createdAt    DateTime       @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([resultsCount])
}

model ErrorLog {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  type       ErrorLogType
  path       String?
  statusCode Int?
  durationMs Int?
  message    String?
  createdAt  DateTime     @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([statusCode])
}

model UsageDailyStat {
  id        String             @id @default(auto()) @map("_id") @db.ObjectId
  date      DateTime
  category  UsageDailyCategory
  label     String
  count     Int
  createdAt DateTime           @default(now())

  @@unique([date, category, label])
  @@index([date, category])
  @@index([category, label])
}

model ErrorDailyStat {
  id              String             @id @default(auto()) @map("_id") @db.ObjectId
  date            DateTime
  category        ErrorDailyCategory
  label           String
  count           Int
  totalDurationMs Int?
  createdAt       DateTime           @default(now())

  @@unique([date, category, label])
  @@index([date, category])
  @@index([category, label])
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

enum DbMigrationStatus {
  RUNNING
  APPLIED
  FAILED
}

model DbMigration {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Identifiant stable de migration (souvent basé sur le nom de fichier)
  name     String            @unique
  checksum String
  status   DbMigrationStatus @default(RUNNING)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  error      String?

  @@map("migrations")
}
